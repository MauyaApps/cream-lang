{
  "Say": {
    "prefix": "say",
    "body": ["say \"$1\""],
    "description": "Print to console"
  },
  "If": {
    "prefix": "if",
    "body": ["if $1", "\t$2"],
    "description": "If condition"
  },
  "If Else": {
    "prefix": "ife",
    "body": ["if $1", "\t$2", "else", "\t$3"],
    "description": "If else condition"
  },
  "Action": {
    "prefix": "action",
    "body": ["action ${1:name}(${2:params})", "\t${3:return $4}"],
    "description": "Define a function"
  },
  "Repeat": {
    "prefix": "repeat",
    "body": ["repeat ${1:3}", "\t$2"],
    "description": "Repeat N times"
  },
  "For Each": {
    "prefix": "for",
    "body": ["for each ${1:x} in ${2:list}", "\t$3"],
    "description": "For each loop"
  },
  "While": {
    "prefix": "while",
    "body": ["while ${1:condition}", "\t$2"],
    "description": "While loop"
  },
  "Struct": {
    "prefix": "struct",
    "body": ["struct ${1:Name}", "\t${2:field}: ${3:text}"],
    "description": "Define a struct"
  },
  "Try Catch": {
    "prefix": "try",
    "body": ["try", "\t${1}", "on error e", "\tsay \"Error: {e.message}\""],
    "description": "Try/catch error handling"
  },
  "Task": {
    "prefix": "task",
    "body": ["task ${1:name}(${2:params})", "\t${3:data} = wait ${4}", "\treturn ${3}"],
    "description": "Async function"
  },
  "Pipeline": {
    "prefix": "pipe",
    "body": [
      "${1:list}",
      "\t| filter(x → x ${2:> 0})",
      "\t| map(x → x ${3:* 2})",
      "\t| sum"
    ],
    "description": "Pipeline chain"
  },
  "Net GET": {
    "prefix": "net",
    "body": [
      "try",
      "\tdata = net(\"${1:url}\", \"json\")",
      "\tsay data",
      "on error e",
      "\tsay \"Error: {e.message}\""
    ],
    "description": "HTTP GET request"
  },
  "File Read": {
    "prefix": "file",
    "body": ["content = file(\"${1:file.txt}\")"],
    "description": "Read a file"
  },
  "Import": {
    "prefix": "import",
    "body": ["import \"${1:file.cream}\""],
    "description": "Import a .cream file"
  }
}
