{
  "name": "Cream",
  "scopeName": "source.cream",
  "fileTypes": ["cream"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#lambda" },
    { "include": "#pipeline" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.cream",
      "match": "--.*$"
    },

    "strings": {
      "name": "string.quoted.double.cream",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cream",
          "match": "\\\\."
        },
        {
          "name": "variable.other.interpolated.cream",
          "match": "\\{[^}]+\\}"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cream",
          "match": "\\b(if|else|or if|for each|in|repeat|while|try|on error)\\b"
        },
        {
          "name": "keyword.declaration.cream",
          "match": "\\b(action|task|struct|import)\\b"
        },
        {
          "name": "keyword.other.cream",
          "match": "\\b(return|wait|together|say)\\b"
        }
      ]
    },

    "builtins": {
      "name": "support.function.builtin.cream",
      "match": "\\b(math|num|rand|stats|convert|str_|text_|regex|list|table|file|folder|sys_|encode|net|date|print_|length|sum|min|max|abs|round|range|sort|reverse|first|last|join|split|upper|lower|trim|contains|number|bool|input)\\b(?=\\()"
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.cream",
          "match": "\\b(yes|no)\\b"
        },
        {
          "name": "constant.language.null.cream",
          "match": "\\bempty\\b"
        },
        {
          "name": "constant.language.cream",
          "match": "\\b(PI|E|INF)\\b"
        }
      ]
    },

    "numbers": {
      "name": "constant.numeric.cream",
      "match": "\\b-?[0-9]+\\.?[0-9]*\\b"
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.cream",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.arithmetic.cream",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.cream",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.assignment.cream",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    },

    "lambda": {
      "name": "keyword.operator.lambda.cream",
      "match": "(→|->)"
    },

    "pipeline": {
      "name": "keyword.operator.pipeline.cream",
      "match": "(?<![|])\\|(?![|])"
    },

    "function-call": {
      "name": "entity.name.function.cream",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },

    "identifiers": {
      "name": "variable.other.cream",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
